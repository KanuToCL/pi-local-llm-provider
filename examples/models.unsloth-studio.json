{
  "_comment": "pi-mono custom-provider config for Unsloth Studio. Drop into ~/.pi/agent/models.json (or merge with existing). Pre-req: probe-toolcalls.js exits 0 against this endpoint. Schema reference: <pi-coding-agent>/docs/models.md.",

  "providers": {
    "unsloth-studio": {
      "baseUrl": "http://localhost:8888/v1",
      "api": "openai-completions",
      "apiKey": "UNSLOTH_API_KEY",
      "authHeader": true,

      "models": [
        {
          "id": "unsloth/Qwen3.6-27B-GGUF",
          "name": "Qwen3.6 27B (Unsloth Studio, local)",
          "reasoning": true,
          "input": ["text"],
          "contextWindow": 32768,
          "maxTokens": 16384,

          "cost": {
            "_comment": "Required by pi-mono's calculateCost — local backends MUST declare 0 or pi will report fake dollars per turn.",
            "input": 0,
            "output": 0,
            "cacheRead": 0,
            "cacheWrite": 0
          },

          "compat": {
            "supportsDeveloperRole": false,
            "supportsReasoningEffort": false,
            "maxTokensField": "max_tokens",
            "thinkingFormat": "qwen-chat-template"
          }
        }
      ]
    }
  }
}
