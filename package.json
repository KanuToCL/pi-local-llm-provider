{
  "name": "pi-local-llm-provider",
  "version": "0.2.0-alpha.1",
  "description": "Configs, probe, helpers, AND the pi-comms daemon — make pi-mono reachable on local LLMs (Unsloth Studio, Ollama, LM Studio, vLLM) and from Telegram + WhatsApp DMs.",
  "license": "MIT",
  "author": "Sergio Pena <https://sergiopena.audio> (@KanuToCL)",
  "homepage": "https://github.com/KanuToCL/pi-local-llm-provider",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KanuToCL/pi-local-llm-provider.git"
  },
  "bugs": {
    "url": "https://github.com/KanuToCL/pi-local-llm-provider/issues"
  },
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "probe": "node scripts/probe-toolcalls.js",
    "studio-variant": "node scripts/studio-variant.js",
    "spike": "tsx scripts/sdk-spike.ts",
    "daemon": "tsx src/daemon.ts",
    "cli": "tsx bin/pi-comms.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "grammy": "^1.42.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.5"
  },
  "optionalDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@whiskeysockets/baileys": "7.0.0-rc.9"
  },
  "keywords": [
    "pi-package",
    "pi-mono",
    "pi-coding-agent",
    "local-llm",
    "unsloth",
    "ollama",
    "openai-compatible",
    "qwen",
    "telegram-bot",
    "whatsapp-bot",
    "coding-agent"
  ]
}
