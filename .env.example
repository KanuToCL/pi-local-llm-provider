# pi-local-llm-provider — copy to .env and fill in. .env is gitignored.

# === Telegram channel (Phase 1) ===
# Get from @BotFather on Telegram: /newbot → pick name → copy token
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram numeric user IDs allowed to talk to pi.
# Find yours by messaging @userinfobot on Telegram.
TELEGRAM_ALLOWED_USER_IDS=

# === pi-mono / Studio backend ===
# Same key your existing pi-mono CLI uses. Mint via Studio UI Settings → API Keys.
UNSLOTH_API_KEY=

# Path to your pi-mono models.json (default ~/.pi/agent/models.json)
# PI_MODELS_JSON=

# pi-mono provider/model id from your ~/.pi/agent/models.json
PI_COMMS_DEFAULT_MODEL=unsloth-studio/unsloth/Qwen3.6-27B-GGUF

# === pi-comms daemon configuration ===
# Daemon runtime state lives at ~/.pi-comms/ by default (mode 0700)
# PI_COMMS_HOME=

# Operator log preferences (mirror gemini-claw)
OPERATOR_LOG_STYLE=pretty           # pretty, plain, or json
OPERATOR_LOG_LEVEL=info             # silent, info, or debug
OPERATOR_LOG_CONTENT=false          # true prints full prompts/responses (privacy-off default)
OPERATOR_LOG_PREVIEW_CHARS=120

# Auto-promote threshold (ms): below this pi reply is sync; above, system promotes to background
PI_COMMS_AUTO_PROMOTE_MS=30000

# Sandbox posture: 'on' (default) | 'off'-NOT-RECOMMENDED
# Use /unsand at runtime to opt out per-task instead of disabling entirely
PI_COMMS_SANDBOX=on

# Workspace dir for sandboxed bash; if unset, uses ~/.pi-comms/workspace/
# PI_COMMS_WORKSPACE=

# Audit log retention in days (default 90)
PI_COMMS_AUDIT_RETENTION_DAYS=90

# Diagnostic mode — writes full prompts/responses to a separate log file
# with 24h auto-purge. NEVER prints to console. Default off.
PI_COMMS_DIAGNOSTIC_MODE=false

# === WhatsApp channel (Phase 5) ===
# Identity model: 'self-chat' (Sergio's number, no second number) | 'second-number' (recommended)
# WHATSAPP_IDENTITY_MODEL=second-number
# WHATSAPP_OWNER_JID=15105551234@s.whatsapp.net
# WHATSAPP_BOT_JID=15106666666@s.whatsapp.net    # Model B only
