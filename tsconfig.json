{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "allowJs": false
  },
  "include": ["src/**/*", "bin/**/*", "scripts/**/*.ts", "tests/**/*"],
  "exclude": ["node_modules", "dist", "scripts/**/*.js", "extensions/**/*"]
}
